# AppWrite Configuration
# Copy this file to .env and fill in your actual values

# AppWrite endpoint (cloud or self-hosted)
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# AppWrite Project ID (get from AppWrite console)
APPWRITE_PROJECT_ID=YOUR_PROJECT_ID

# Database ID (usually same as project ID for default database)
APPWRITE_DATABASE_ID=YOUR_DATABASE_ID

# Collection IDs (create these collections first)
APPWRITE_CONTACT_COLLECTION_ID=YOUR_CONTACT_COLLECTION_ID
APPWRITE_CHAT_COLLECTION_ID=YOUR_CHAT_COLLECTION_ID
APPWRITE_PORTFOLIO_COLLECTION_ID=YOUR_PORTFOLIO_COLLECTION_ID

# Optional: API Key for server-side operations
# APPWRITE_API_KEY=YOUR_API_KEY
